<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:startColor="#C62828"
                android:endColor="#8E1B1B"
                android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="180dp"
                android:centerX="0.2"
                android:centerY="0.0"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
