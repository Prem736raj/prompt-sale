<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/featured_dark">

        <!-- Background Image -->
        <ImageView
            android:id="@+id/ivFeaturedBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:alpha="0.6" />

        <!-- Gradient Overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/featured_gradient" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="bottom">

            <TextView
                android:id="@+id/tvFeaturedTitle"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Create Full Apps from AI"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/tvFeaturedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="150+ Prompts"
                android:textColor="#BBFFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBuildNow"
                android:layout_width="120dp"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/accent_blue"
                android:text="@string/build_now"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>
